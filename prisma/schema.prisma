// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id       String   @id
  title    String
  venue    String
  startsAt DateTime @map("starts_at")
  tiers    Tier[]

  @@map("events")
}

model Tier {
  id             String @id
  eventId        String @map("event_id")
  name           String
  price          Int
  currency       String
  totalInventory Int    @map("total_inventory")

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  holds  Hold[]
  orders Order[]

  @@map("tiers")
}

enum HoldStatus {
  active
  expired
  converted
}

model Hold {
  id        String     @id @default(uuid())
  tierId    String     @map("tier_id")
  quantity  Int
  expiresAt DateTime   @map("expires_at")
  status    HoldStatus @default(active)

  tier Tier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt]) // High-performance index for expiry mechanics
  @@map("holds")
}

enum OrderStatus {
  paid
  refunded
}

model Order {
  id       String      @id // External processor order_id is the source of truth
  tierId   String      @map("tier_id")
  quantity Int
  status   OrderStatus
  tier     Tier        @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model WebhookEvent {
  id          String   @id // The webhook event_id — globally unique per delivery, serves as the idempotency key
  type        String   @map("event_type")
  payload     Json
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("webhook_events")
}
